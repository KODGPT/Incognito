{
  "manifest_version": 3,
  "name": "Open in Incognito",
  "description": "Opens current page in incognito window",
  "version": "1.0",

  "permissions": [
    "tabs"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Open in Incognito",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}